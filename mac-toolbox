#!/bin/bash

# ============================================================
# mac-toolbox — Unified CLI for all macOS utilities
#
# Single entry point for 10 zero-dependency tools.
#
# Usage:
#   ./mac-toolbox <tool> [args...]
#   ./mac-toolbox install        # Add 'mactool' alias to shell
#   ./mac-toolbox list           # List all tools
#   ./mac-toolbox help           # Show help
#
# After install:
#   mactool uninstall --dry-run
#   mactool disk --hogs
#   mactool dev
# ============================================================

set -uo pipefail

VERSION="1.0.0"

# Resolve real path (works even if called via symlink/alias)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TOOLS_DIR="${SCRIPT_DIR}/tools"

# ===================== COLORS =====================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

divider() { echo -e "${DIM}$(printf '─%.0s' {1..60})${NC}"; }

# ===================== TOOL REGISTRY =====================
# shortname|filename|description|category
TOOLS=(
    "uninstall|uninstall.sh|Remove apps completely + orphan scanner|cleanup"
    "disk|diskmap.sh|Disk space analyzer + space hog detector|cleanup"
    "dupes|dupes.sh|Find and remove duplicate files|cleanup"
    "dev|dev-clean.sh|Clean dev artifacts (node_modules, etc.)|cleanup"
    "brew|brew-doctor.sh|Homebrew hygiene and cleanup|cleanup"
    "launch|launchctl-manager.sh|Manage startup agents and daemons|system"
    "defaults|defaults-manager.sh|macOS hidden preferences manager|system"
    "privacy|privacy-audit.sh|Privacy permissions audit|system"
    "battery|battery.sh|Battery health and power diagnostics|diagnostics"
    "net|netcheck.sh|Network diagnostics and benchmarks|diagnostics"
    "update|update-prep.sh|Pre-update readiness checklist|diagnostics"
)

# ===================== LOOKUP =====================
get_tool_field() {
    local shortname="$1"
    local field="$2"  # 1=shortname 2=filename 3=description 4=category

    for entry in "${TOOLS[@]}"; do
        local IFS_BAK="$IFS"
        IFS='|'
        set -- $entry
        IFS="$IFS_BAK"

        if [ "$1" = "$shortname" ]; then
            case "$field" in
                filename) echo "$2" ;;
                desc)     echo "$3" ;;
                category) echo "$4" ;;
            esac
            return 0
        fi
    done
    return 1
}

resolve_tool_path() {
    local shortname="$1"
    local filename
    filename=$(get_tool_field "$shortname" "filename") || return 1
    local full_path="${TOOLS_DIR}/${filename}"

    if [ -x "$full_path" ]; then
        echo "$full_path"
        return 0
    fi
    return 1
}

# ===================== LIST TOOLS =====================
list_tools() {
    echo ""
    echo -e "${CYAN}${BOLD}  mac-toolbox v${VERSION}${NC}"
    echo -e "  ${DIM}10 zero-dependency macOS utilities${NC}"
    echo ""

    local current_cat=""

    for entry in "${TOOLS[@]}"; do
        local IFS_BAK="$IFS"
        IFS='|'
        set -- $entry
        IFS="$IFS_BAK"

        local shortname="$1"
        local filename="$2"
        local desc="$3"
        local category="$4"

        # Print category header
        if [ "$category" != "$current_cat" ]; then
            current_cat="$category"
            echo ""
            local cat_label
            case "$category" in
                cleanup)     cat_label="Cleanup & Storage" ;;
                system)      cat_label="System Management" ;;
                diagnostics) cat_label="Diagnostics" ;;
                *)           cat_label="$category" ;;
            esac
            echo -e "  ${BOLD}${cat_label}${NC}"
            divider
        fi

        # Check if tool exists
        local status=""
        if [ -x "${TOOLS_DIR}/${filename}" ]; then
            status="${GREEN}●${NC}"
        else
            status="${RED}○${NC}"
        fi

        printf "  %b  ${GREEN}%-12s${NC} %s\n" "$status" "$shortname" "$desc"
    done

    echo ""
    divider
    echo -e "  ${DIM}Usage: mac-toolbox <tool> [args...]${NC}"
    echo -e "  ${DIM}       mactool <tool> [args...]     (after install)${NC}"
    echo ""
    echo -e "  ${DIM}Examples:${NC}"
    echo -e "    ${CYAN}mactool disk --hogs${NC}          Scan for space hogs"
    echo -e "    ${CYAN}mactool uninstall --dry-run${NC}  Preview app cleanup"
    echo -e "    ${CYAN}mactool dev${NC}                  Clean dev artifacts"
    echo -e "    ${CYAN}mactool launch${NC}               Manage startup items"
    echo -e "    ${CYAN}mactool privacy${NC}              Audit app permissions"
    echo ""
}

# ===================== INSTALL ALIAS =====================
install_alias() {
    echo ""
    echo -e "${CYAN}${BOLD}  Installing mac-toolbox...${NC}"
    echo ""

    local entry_point="${SCRIPT_DIR}/mac-toolbox"

    # Verify entry point exists
    if [ ! -f "$entry_point" ]; then
        echo -e "  ${RED}Error: Cannot find mac-toolbox at ${entry_point}${NC}"
        return 1
    fi

    # Make everything executable
    chmod +x "$entry_point" 2>/dev/null
    chmod +x "${TOOLS_DIR}"/*.sh 2>/dev/null
    echo -e "  ${GREEN}✓${NC} Made all tools executable"

    # Detect shell config file
    local shell_rc=""
    local current_shell
    current_shell=$(basename "${SHELL:-/bin/zsh}")

    case "$current_shell" in
        zsh)  shell_rc="$HOME/.zshrc" ;;
        bash)
            # macOS bash uses .bash_profile for login shells
            if [ -f "$HOME/.bash_profile" ]; then
                shell_rc="$HOME/.bash_profile"
            else
                shell_rc="$HOME/.bashrc"
            fi
            ;;
        fish) shell_rc="$HOME/.config/fish/config.fish" ;;
        *)    shell_rc="$HOME/.profile" ;;
    esac

    # Lines to add
    local marker="# mac-toolbox"
    local alias_line="alias mactool='${entry_point}'"
    local path_line="export PATH=\"${TOOLS_DIR}:\$PATH\""

    # Check if already installed
    if [ -f "$shell_rc" ] && grep -q "$marker" "$shell_rc" 2>/dev/null; then
        echo -e "  ${YELLOW}Already installed in ${shell_rc}${NC}"
        echo ""
        echo -e "  ${DIM}To update, remove the existing mac-toolbox block and re-run install.${NC}"
        echo ""

        # Still validate everything works
        echo -e "  ${GREEN}Verifying tools...${NC}"
        verify_tools
        return 0
    fi

    # Add to shell config
    {
        echo ""
        echo "$marker — start"
        echo "$alias_line"
        echo "$path_line"
        echo "$marker — end"
    } >> "$shell_rc"

    echo -e "  ${GREEN}✓${NC} Added alias to ${shell_rc}:"
    echo ""
    echo -e "    ${DIM}${alias_line}${NC}"
    echo -e "    ${DIM}${path_line}${NC}"
    echo ""

    # Verify tools
    verify_tools

    echo ""
    divider
    echo ""
    echo -e "  ${BOLD}Setup complete!${NC} Run this to activate now:"
    echo ""
    echo -e "    ${CYAN}source ${shell_rc}${NC}"
    echo ""
    echo -e "  Then use:"
    echo ""
    echo -e "    ${CYAN}mactool${NC}             Show all tools"
    echo -e "    ${CYAN}mactool disk${NC}        Disk analyzer"
    echo -e "    ${CYAN}mactool uninstall${NC}   App uninstaller"
    echo ""
    echo -e "  ${DIM}Or run tools directly:${NC}"
    echo -e "    ${CYAN}diskmap.sh --hogs${NC}   (tools are also in PATH)"
    echo ""
}

verify_tools() {
    local ok=0
    local missing=0

    for entry in "${TOOLS[@]}"; do
        local IFS_BAK="$IFS"
        IFS='|'
        set -- $entry
        IFS="$IFS_BAK"

        local shortname="$1"
        local filename="$2"

        if [ -x "${TOOLS_DIR}/${filename}" ]; then
            ((ok++))
        else
            echo -e "  ${RED}✗${NC} Missing: ${filename}"
            ((missing++))
        fi
    done

    if [ $missing -eq 0 ]; then
        echo -e "  ${GREEN}✓${NC} All ${ok} tools verified"
    else
        echo -e "  ${YELLOW}!${NC} ${missing} tool(s) missing"
    fi
}

# ===================== UNINSTALL ALIAS =====================
uninstall_alias() {
    echo ""
    echo -e "${CYAN}${BOLD}  Uninstalling mac-toolbox alias...${NC}"
    echo ""

    local marker="# mac-toolbox"

    # Check common shell configs
    for rc in "$HOME/.zshrc" "$HOME/.bash_profile" "$HOME/.bashrc" "$HOME/.profile" "$HOME/.config/fish/config.fish"; do
        [ ! -f "$rc" ] && continue

        if grep -q "$marker" "$rc" 2>/dev/null; then
            # Remove the block between markers
            local tmp
            tmp=$(mktemp)
            local in_block=false
            while IFS= read -r line; do
                if [[ "$line" == *"$marker — start"* ]]; then
                    in_block=true
                    continue
                fi
                if [[ "$line" == *"$marker — end"* ]]; then
                    in_block=false
                    continue
                fi
                if [ "$in_block" = false ]; then
                    echo "$line" >> "$tmp"
                fi
            done < "$rc"

            mv "$tmp" "$rc"
            echo -e "  ${GREEN}✓${NC} Removed from ${rc}"
        fi
    done

    echo ""
    echo -e "  ${DIM}Alias removed. Restart your terminal or run:${NC}"
    echo -e "    ${CYAN}unalias mactool 2>/dev/null; hash -r${NC}"
    echo ""
}

# ===================== HELP =====================
show_help() {
    echo ""
    echo -e "${BOLD}mac-toolbox v${VERSION}${NC} — Zero-dependency macOS utilities"
    echo ""
    echo "Usage:"
    echo "  mac-toolbox <tool> [args...]    Run a tool"
    echo "  mac-toolbox list                List all tools"
    echo "  mac-toolbox install             Add 'mactool' alias to shell"
    echo "  mac-toolbox uninstall-alias     Remove the alias"
    echo "  mac-toolbox help                Show this help"
    echo "  mac-toolbox version             Show version"
    echo ""
    echo "Tools:"
    echo "  uninstall    App uninstaller + orphan scanner"
    echo "  disk         Disk space analyzer"
    echo "  dupes        Duplicate file finder"
    echo "  dev          Dev artifact cleaner"
    echo "  brew         Homebrew hygiene"
    echo "  launch       Startup process manager"
    echo "  defaults     Hidden preferences manager"
    echo "  privacy      Permission audit"
    echo "  battery      Battery health report"
    echo "  net          Network diagnostics"
    echo "  update       Pre-update checklist"
    echo ""
    echo "Examples:"
    echo "  mactool disk --hogs             Find space hogs"
    echo "  mactool uninstall --dry-run     Preview app removal"
    echo "  mactool dev --stale-days 60     Find old project artifacts"
    echo "  mactool launch --dry-run        Preview startup changes"
    echo ""
    echo "All destructive tools support --dry-run for safe preview."
    echo ""
}

# ===================== INTERACTIVE MENU =====================
interactive_menu() {
    clear
    echo ""
    echo -e "${CYAN}${BOLD}  ╔════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}${BOLD}  ║  mac-toolbox v${VERSION}                                    ║${NC}"
    echo -e "${CYAN}${BOLD}  ║  ${DIM}10 zero-dependency macOS utilities${CYAN}${BOLD}                   ║${NC}"
    echo -e "${CYAN}${BOLD}  ╚════════════════════════════════════════════════════════╝${NC}"
    echo ""

    echo -e "  ${BOLD}Cleanup & Storage${NC}"
    divider
    echo -e "  ${GREEN} 1.${NC}  uninstall    Remove apps + orphan scanner"
    echo -e "  ${GREEN} 2.${NC}  disk         Disk space analyzer"
    echo -e "  ${GREEN} 3.${NC}  dupes        Duplicate file finder"
    echo -e "  ${GREEN} 4.${NC}  dev          Dev artifact cleaner"
    echo -e "  ${GREEN} 5.${NC}  brew         Homebrew hygiene"
    echo ""
    echo -e "  ${BOLD}System Management${NC}"
    divider
    echo -e "  ${GREEN} 6.${NC}  launch       Startup process manager"
    echo -e "  ${GREEN} 7.${NC}  defaults     Hidden preferences"
    echo -e "  ${GREEN} 8.${NC}  privacy      Permission audit"
    echo ""
    echo -e "  ${BOLD}Diagnostics${NC}"
    divider
    echo -e "  ${GREEN} 9.${NC}  battery      Battery health"
    echo -e "  ${GREEN}10.${NC}  net          Network diagnostics"
    echo -e "  ${GREEN}11.${NC}  update       Pre-update checklist"
    echo ""
    divider
    echo -e "  ${GREEN} i.${NC}  Install 'mactool' alias"
    echo -e "  ${GREEN} q.${NC}  Quit"
    echo ""

    read -rp "  > " choice

    local tool_name=""
    case "$choice" in
        1)  tool_name="uninstall" ;;
        2)  tool_name="disk" ;;
        3)  tool_name="dupes" ;;
        4)  tool_name="dev" ;;
        5)  tool_name="brew" ;;
        6)  tool_name="launch" ;;
        7)  tool_name="defaults" ;;
        8)  tool_name="privacy" ;;
        9)  tool_name="battery" ;;
        10) tool_name="net" ;;
        11) tool_name="update" ;;
        i|I) install_alias; read -rp "  Press Enter..." _; interactive_menu; return ;;
        q|Q) echo -e "\n  ${GREEN}Done.${NC}\n"; exit 0 ;;
        *)  echo -e "  ${RED}Invalid.${NC}"; sleep 0.5; interactive_menu; return ;;
    esac

    if [ -n "$tool_name" ]; then
        local tool_path
        tool_path=$(resolve_tool_path "$tool_name")
        if [ -n "$tool_path" ]; then
            exec "$tool_path"
        else
            echo -e "  ${RED}Tool not found: ${tool_name}${NC}"
            sleep 1
            interactive_menu
        fi
    fi
}

# ===================== MAIN DISPATCH =====================
main() {
    # No args → interactive menu
    if [ $# -eq 0 ]; then
        interactive_menu
        exit 0
    fi

    local command="$1"
    shift

    case "$command" in
        # Meta commands
        list|ls)
            list_tools
            ;;
        install|setup)
            install_alias
            ;;
        uninstall-alias|remove-alias)
            uninstall_alias
            ;;
        help|-h|--help)
            show_help
            ;;
        version|-v|--version)
            echo "mac-toolbox v${VERSION}"
            ;;

        # Tool dispatch
        *)
            local tool_path
            tool_path=$(resolve_tool_path "$command") || true

            if [ -n "$tool_path" ] && [ -x "$tool_path" ]; then
                exec "$tool_path" "$@"
            else
                # Fuzzy suggestion
                echo -e "${RED}Unknown command: ${command}${NC}"
                echo ""

                # Check for partial matches
                local suggestions=""
                for entry in "${TOOLS[@]}"; do
                    local shortname="${entry%%|*}"
                    if [[ "$shortname" == *"$command"* ]] || [[ "$command" == *"$shortname"* ]]; then
                        suggestions+="  ${GREEN}${shortname}${NC}\n"
                    fi
                done

                if [ -n "$suggestions" ]; then
                    echo -e "Did you mean:"
                    echo -e "$suggestions"
                fi

                echo "Run 'mac-toolbox help' for usage."
                exit 1
            fi
            ;;
    esac
}

main "$@"
